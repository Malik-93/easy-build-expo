# =============================================
# easy-build-expo — Environment Variables
# =============================================
# Copy this file to .env and fill in your values

# --- App ---
NODE_ENV=development
APP_URL=http://localhost:3000
WEB_URL=http://localhost:3001

# --- Database ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/easy_build_expo

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT Auth ---
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# --- GitHub OAuth ---
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# --- Google Drive (Artifact Storage) ---
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_root_folder_id

# --- Google Play Store ---
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# --- Encryption (AES-256 for keystores/secrets) ---
# Should be a 32-character hex string
ENCRYPTION_KEY=your_32_char_hex_encryption_key_here

# --- Slack (Optional notifications) ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# --- Cloudflare / OTA CDN ---
CDN_BASE_URL=https://your-cdn-domain.com

# --- Build Worker ---
BUILD_CONCURRENCY=5
BUILD_TIMEOUT_MS=600000
